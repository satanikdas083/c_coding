#include <stdio.h>

int main() {
int num, a[10], i = 0, j;

printf("Enter a number: ");      
scanf("%d", &num);      
  
   
while (num != 0) {      
    a[i] = num % 10;      
    num = num / 10;      
    i++;      
}      
  
      
for (j = 0; j < i/2; j++) {      
    if (a[j] != a[i - j - 1]) {      
        printf("Not Palindrome");      
         break;    
    }      
}      
  
  
printf("Palindrome");      
  
return 0;

}